---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Marmolería Dodedra | Mesadas de Mármol y Granito a Medida</title>
		<meta name="description" content="Marmolería Dodedra: Fabricamos e instalamos mesadas de mármol, granito y cuarzo. Calidad y diseño en cada proyecto. ¡Solicitá tu presupuesto!" />
		<meta name="keywords" content="marmolería, mesadas de mármol, granito, cuarzo, revestimientos, escaleras de mármol, encimeras de cocina" />
		<meta name="author" content="Marmolería Dodedra" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://tudominio.com" />
		<link rel="icon" type="image/png" href="/Logo.png" />

		<!-- Open Graph (para compartir en Facebook, WhatsApp, LinkedIn) -->
		<meta property="og:title" content="Marmolería Dodedra | Mesadas de Mármol y Granito a Medida" />
		<meta property="og:description" content="Especialistas en mesadas de mármol, granito y cuarzo. Calidad y diseño a medida. Pedí tu presupuesto sin compromiso." />
		<meta property="og:image" content="https://tudominio.com/imagen-destacada.jpg" />
		<meta property="og:url" content="https://tudominio.com" />
		<meta property="og:type" content="website" />

		<!-- Twitter Card (para mejorar la apariencia en Twitter) -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Marmolería Dodedra | Mesadas de Mármol y Granito a Medida" />
		<meta name="twitter:description" content="Fabricamos e instalamos mesadas de mármol, granito y cuarzo. Calidad garantizada." />
		<meta name="twitter:image" content="https://tudominio.com/imagen-destacada.jpg" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">

	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: "Open Sans", sans-serif;
	}
</style>
